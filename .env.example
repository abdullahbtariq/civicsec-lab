# CivicSec Lab local development settings

COMPOSE_PROJECT_NAME=civicsec_lab

DJANGO_SETTINGS_MODULE=civicsec.settings.dev
SECRET_KEY=dev-only-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=True

POSTGRES_DB=civicsec_lab
POSTGRES_USER=civicsec
POSTGRES_PASSWORD=civicsec_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://civicsec:civicsec_dev_password@postgres:5432/civicsec_lab

REDIS_URL=redis://redis:6379/0

VITE_API_BASE_URL=http://localhost:8000
